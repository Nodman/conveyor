#!/usr/bin/env bash
set -euo pipefail
echo "$*" >> "${GH_LOG:?}"

if [[ "${1:-}" == "api" && "${2:-}" == "graphql" ]]; then
  body="$*"
  for a in "$@"; do [[ "$a" == "-" ]] && body="$body $(cat)"; done
  shopt -s nullglob
  for f in "$GH_FIX"/graphql_*.out; do
    op="$(basename "$f")"; op="${op#graphql_}"; op="${op%.out}"
    if [[ "$body" == *"$op"* ]]; then cat "$f"; exit 0; fi
  done
  echo "gh-stub: no graphql fixture matching: $body" >&2; exit 64
fi

key="${1:-}_${2:-}"
if [[ -f "$GH_FIX/$key.out" ]]; then cat "$GH_FIX/$key.out"; exit 0; fi
echo "gh-stub: no fixture for: $*" >&2; exit 64
