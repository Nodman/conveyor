#!/usr/bin/env bash
set -euo pipefail
echo "codex $*" >> "${RUN_LOG:?}"
if [[ "${1:-}" == "login" ]]; then echo "Logged in (mock)"; exit 0; fi
if [[ "${1:-}" == "--version" ]]; then echo "codex-cli 0.144.1-mock"; exit 0; fi
has_resume="" has_s="" has_json="" has_color=""
for a in "$@"; do
  [[ "$a" == "resume" ]] && has_resume=1
  [[ "$a" == "-s" ]] && has_s=1
  [[ "$a" == "--json" ]] && has_json=1
  [[ "$a" == "--color" ]] && has_color=1
done
if [[ -n "$has_resume" && -n "$has_s" ]]; then
  echo "error: unexpected argument '-s' found" >&2
  exit 2
fi
if [[ -n "$has_resume" && -n "$has_color" ]]; then
  echo "error: unexpected argument '--color' found" >&2
  exit 2
fi
has_strict=""
for a in "$@"; do [[ "$a" == "--strict-config" ]] && has_strict=1; done
if [[ -n "$has_strict" ]]; then
  prev=""
  for a in "$@"; do
    if [[ "$prev" == "-c" ]]; then
      key="${a%%=*}"
      case "$key" in
        sandbox_mode|approval_policy|approvals_reviewer|auto_review.policy) ;;
        *) echo "error: unknown config key '$key' (--strict-config)" >&2; exit 1 ;;
      esac
    fi
    prev="$a"
  done
fi
out="" prev=""
for a in "$@"; do
  if [[ "$prev" == "-o" ]]; then out="$a"; fi
  prev="$a"
done
if [[ ! -t 0 ]]; then cat > "${CODEX_STUB_PROMPT_CAPTURE:-/dev/null}"; fi
if [[ -n "${CODEX_STUB_ESCALATION:-}" ]]; then
  # canary always runs in a throwaway dir → real CLI refuses without --skip-git-repo-check
  has_skip=""
  for a in "$@"; do [[ "$a" == "--skip-git-repo-check" ]] && has_skip=1; done
  if [[ -z "$has_skip" ]]; then
    echo "Not inside a trusted directory and --skip-git-repo-check was not specified." >&2
    exit 1
  fi
  case "$CODEX_STUB_ESCALATION" in
    ok)
      # emit both role canary shapes (exit 0) so exec and review detection both pass
      echo '{"type":"thread.started","thread_id":"0000-canary"}'
      echo '{"type":"item.completed","item":{"id":"c0","type":"command_execution","command":"gh api --method GET repos/acme/widget --jq .full_name","aggregated_output":"","exit_code":0,"status":"completed"}}'
      echo '{"type":"item.completed","item":{"id":"c1","type":"command_execution","command":"git -c core.hooksPath=/dev/null commit --allow-empty --no-verify --no-gpg-sign -m conveyor-canary","aggregated_output":"","exit_code":0,"status":"completed"}}'
      echo '{"type":"turn.completed","usage":{"input_tokens":1,"output_tokens":1}}' ;;
    denied)
      echo '{"type":"item.completed","item":{"id":"c0","type":"agent_message","text":"Approval policy is currently never; refusing the privileged command."}}' ;;
  esac
  exit 0
fi
if [[ -n "${MOCK_CODEX_FAIL:-}" ]]; then
  echo "Not inside a trusted directory and --skip-git-repo-check was not specified."
  exit "$MOCK_CODEX_FAIL"
fi
if [[ -n "$has_json" ]]; then
  echo '{"type":"thread.started","thread_id":"0000-mock-session"}'
  echo '{"type":"item.started","item":{"id":"i0","type":"command_execution","command":"echo hi","status":"in_progress"}}'
  echo '{"type":"item.completed","item":{"id":"i0","type":"command_execution","command":"echo hi","aggregated_output":"hi","exit_code":0,"status":"completed"}}'
  echo "{\"type\":\"item.completed\",\"item\":{\"id\":\"i1\",\"type\":\"file_change\",\"changes\":[{\"path\":\"$PWD/mock.txt\",\"kind\":\"add\"}],\"status\":\"completed\"}}"
  echo '{"type":"item.completed","item":{"id":"i2","type":"agent_message","text":"mock final message"}}'
  echo '{"type":"turn.completed","usage":{"input_tokens":100,"output_tokens":10}}'
else
  echo "session id: 0000-mock-session"
  echo "codex mock ran"
fi
if [[ -n "$out" ]]; then printf 'mock final message\n' > "$out"; fi
