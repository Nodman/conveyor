{
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "privileged_actions", "denials", "commit_shas", "tests"],
  "properties": {
    "verdict": { "type": "string", "enum": ["approve", "request-changes", "comment"] },
    "privileged_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code"],
        "properties": {
          "command": { "type": "string" },
          "exit_code": { "type": "integer" }
        }
      }
    },
    "denials": { "type": "array", "items": { "type": "string" } },
    "commit_shas": { "type": "array", "items": { "type": "string" } },
    "tests": { "type": "array", "items": { "type": "string" } }
  }
}
